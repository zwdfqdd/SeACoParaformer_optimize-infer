# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# 虚拟环境
venv/
.venv/
env/

# 模型文件（体积大，不纳入版本控制）
models/asr/**/*.onnx
models/asr/**/*.bin
models/asr/**/*.pt
models/asr/**/seg_dict
models/vad/**/*.onnx
models/vad/**/*.pt
models/vad/**/*.jit
# 句子级标点模型缓存（ModelScope 下载，体积大不入库；保留 .gitkeep）
models/punc/*
!models/punc/.gitkeep

# 上游参考项目源码（手动下载，不纳入本仓库版本控制）
ngram-punctuator/

# 推理必需的小配置文件纳入版本控制（显式不忽略）
!models/asr/config.yaml
!models/asr/am.mvn
!models/asr/tokens.json
!models/asr/tokens.txt
!models/asr/pt/am.mvn
!models/asr/pt/tokens.json

# IDE
.idea/
.vscode/
*.swp
*.swo

# 环境变量
.env

# 日志
logs/
*.log

# 系统文件
.DS_Store
Thumbs.db

# Kiro IDE 临时文件
.kiro/hooks/
.kiro/session_backup/

# 临时分析报告
report_*.json
tmp_*/
tmp_trt_analyze*/

# 测试音视频样本（体积大，不纳入版本控制）
test_data/*.mp4
test_data/*.mp3
test_data/*.m4a

